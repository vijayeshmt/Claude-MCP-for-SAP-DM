# Default SAP BTP DMC Credentials
DMC_API_ENDPOINT=https://api.eu20.dmc.cloud.sap
DMC_TOKEN_URL=https://<your-subaccount>.authentication.eu20.hana.ondemand.com/oauth/token
DMC_CLIENT_ID=sb-your-client-id
DMC_CLIENT_SECRET=your-client-secret-here
DMC_PLANT=YOUR_PLANT_CODE

# (Optional) Mock Server Settings
MOCK_PORT=3000
